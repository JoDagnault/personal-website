---
import Layout from "./Layout.astro";
import ProjectTags from "../components/projects/ProjectTags.astro";
import SocialLink from "../components/social-links/SocialLink.astro";
import { type LocalizedUrls } from "../i18n/urls.ts";

interface Props {
  title: string;
  description: string;
  date: string;
  tags: string[];
  repoUrl?: string;
  localizedUrls: LocalizedUrls;
}

const { title, description, date, tags, repoUrl, localizedUrls } = Astro.props;
---

<Layout title={title} description={description} localizedUrls={localizedUrls}>
  <article class="project">
    <div class="project-heading">
      <h1>{title}</h1>
      {repoUrl && <SocialLink link={{ name: "GitHub", url: repoUrl, icon: "github" }} />}
    </div>
    <ProjectTags tags={tags} />
    <span class="project-date">{date}</span>
    <slot />
  </article>
</Layout>

<style>
  .project {
    text-align: left;
  }

  .project-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .project-heading h1 {
    margin: 0;
  }

  .project :global(.project-tags) {
    margin: 0.5rem 0;
  }

  .project-date {
    display: block;
    margin-bottom: 2rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .project :global(p) {
    font-size: 1.25rem;
    line-height: 1.6;
  }
</style>
