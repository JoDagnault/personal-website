---
import { resolveLocale } from "../i18n/locales";
import { translations } from "../i18n/translations";
import AboutMe from "./about-me/AboutMe.astro";

const locale = resolveLocale(Astro.currentLocale);
const heroContent = translations[locale].hero;
---

<section class="hero-section">
  <h1 class="hero-name">{heroContent.name}</h1>
  <p class="hero-title">{heroContent.description}</p>
  <AboutMe />
</section>

<style>
  .hero-section {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
  }

  .hero-section :global(.about-me-description) {
    margin-top: 1.5rem;
  }

  .hero-name {
    margin: 0;
    font-size: clamp(1.75rem, 8.5vw, 5rem);
    line-height: 1.1;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-weight: 500;
    color: var(--accent-color);
  }
</style>
