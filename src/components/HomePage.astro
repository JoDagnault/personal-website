---
import { defaultLocale, localePaths, locales, type Locale } from "../i18n/config";
import { ui } from "../i18n/ui";
import Hero from "./Hero.astro";
import AboutMe from "./about-me/AboutMe.astro";
import Header from "./header/Header.astro";
import "../styles/global.css";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const homeContent = ui[locale];
const localeUrl = (targetLocale: Locale) =>
  new URL(localePaths[targetLocale], Astro.site).toString();
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={homeContent.metaDescription} />
    <link rel="canonical" href={localeUrl(locale)} />
    {
      locales.map((alternateLocale) => (
        <link rel="alternate" hreflang={alternateLocale} href={localeUrl(alternateLocale)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={localeUrl(defaultLocale)} />
    <title>{homeContent.siteTitle}</title>
  </head>
  <body>
    <Hero locale={locale} />
    <hr />
    <Header locale={locale} />
    <AboutMe locale={locale} />
  </body>
</html>

<style>
  body {
    font-family: var(--font-body);
    background-color: var(--color-background);
    color: var(--color-text);
    max-width: 80vw;
    margin: auto;
  }

  hr {
    border: 0;
    border-top: 1px solid var(--color-text);
    width: 80%;
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }
</style>
