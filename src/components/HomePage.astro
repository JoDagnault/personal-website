---
import Hero from "./Hero.astro";
import AboutMe from "./about-me/AboutMe.astro";
import Layout from "../layouts/Layout.astro";
import Projects from "./projects/Projects.astro";
import { resolveLocale } from "../i18n/locales";
import { translations } from "../i18n/translations";

const locale = resolveLocale(Astro.currentLocale);
const homeContent = translations[locale];
---

<Layout title={homeContent.siteTitle} description={homeContent.metaDescription}>
  <Hero />
  <hr class="section-divider" />
  <AboutMe />
  <hr class="section-divider" />
  <Projects />
</Layout>

<style>
  .section-divider {
    border: 0;
    border-top: 1px solid var(--text-color);
    width: 80%;
    margin: clamp(3.5rem, 6vw, 5rem) auto;
  }
</style>
