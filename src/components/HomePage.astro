---
import { defaultLocale, localePaths, locales, resolveLocale, type Locale } from "../i18n/locales";
import { translations } from "../i18n/translations";
import Hero from "./Hero.astro";
import AboutMe from "./about-me/AboutMe.astro";
import Header from "./header/Header.astro";
import "../styles/global.css";

const locale = resolveLocale(Astro.currentLocale);
const homeContent = translations[locale];
const localeUrl = (targetLocale: Locale) =>
  new URL(localePaths[targetLocale], Astro.site).toString();
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={homeContent.metaDescription} />
    <link rel="canonical" href={localeUrl(locale)} />
    {
      locales.map((alternateLocale) => (
        <link rel="alternate" hreflang={alternateLocale} href={localeUrl(alternateLocale)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={localeUrl(defaultLocale)} />
    <title>{homeContent.siteTitle}</title>

    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      document.documentElement.dataset.theme =
        savedTheme === "dark" || savedTheme === "light" ? savedTheme : "dark";
    </script>
  </head>
  <body>
    <Header />
    <Hero />
    <hr />
    <AboutMe />
  </body>
</html>

<style>
  body {
    font-family: var(--font-body);
    background-color: var(--background-color);
    color: var(--text-color);
    max-width: 80vw;
    margin: auto;
  }

  hr {
    border: 0;
    border-top: 1px solid var(--text-color);
    width: 80%;
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }
</style>
