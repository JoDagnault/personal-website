---
import type { CollectionEntry } from "astro:content";
import { projectUrl } from "../../i18n/urls.ts";
import ProjectTags from "./ProjectTags.astro";
interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
---

<a class="project-card" href={projectUrl(project)}>
  <h3 class="project-title">{project.data.title}</h3>
  <p class="project-description">{project.data.description}</p>
  <ProjectTags tags={project.data.tags} />
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    height: 100%;
    gap: 0.75rem;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--text-color);
    border: 2px solid var(--border-color);
    border-radius: 0.5rem;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .project-card:hover {
    border-color: var(--accent-color);
    background-color: var(--hover-background-color);
  }

  .project-card:visited {
    color: var(--text-color);
  }

  .project-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
  }

  .project-description {
    margin: 0;
    color: var(--muted-text-color);
    line-height: 1.5;
  }

  .project-card :global(.project-tags) {
    margin-top: auto;
  }
</style>
