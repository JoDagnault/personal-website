---
import ColorPill from "./ColorPill.astro";
import { accentColorCssVariable, accentColors } from "./accentColors.ts";
---

<div class="accent-color-picker header-control" data-header-control="menu">
  <button class="accent-color-picker-button header-button" aria-expanded="false">
    <ColorPill color="var(--accent-color)" />
  </button>

  <ul class="accent-color-picker-menu header-menu">
    {
      accentColors.map((accentColor) => (
        <li class="accent-color-picker-menu-item">
          <button
            class="accent-color-picker-menu-button"
            value={accentColor.id}
            aria-label={accentColor.label}
          >
            <ColorPill color={`var(${accentColorCssVariable(accentColor.id)})`} />
          </button>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .accent-color-picker-menu-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    box-sizing: border-box;
    padding: 0.75rem 1rem;
    border: 0;
    background: none;
    cursor: pointer;
  }

  .accent-color-picker-menu-button:hover {
    background-color: var(--hover-background-color);
  }
</style>

<script>
  import { isAccentColorId, setAccentColor } from "./accentColors.ts";

  const COLOR_BUTTON_SELECTOR = ".accent-color-picker-menu-button";

  const colorButtons = document.querySelectorAll<HTMLButtonElement>(COLOR_BUTTON_SELECTOR);

  for (const colorButton of colorButtons) {
    colorButton.addEventListener("click", () => {
      const accentColor = colorButton.value;

      if (!isAccentColorId(accentColor)) {
        return;
      }

      setAccentColor(accentColor);
    });
  }
</script>
