---
import HomeLink from "./controls/HomeLink.astro";
import LanguagePicker from "./controls/LanguagePicker.astro";
import ThemeToggle from "./controls/ThemeToggle.astro";
import AccentColorPicker from "./controls/accent-color-picker/AccentColorPicker.astro";
import type { LocalizedUrls } from "../../i18n/urls";
import HeaderControlsCluster from "./controls/HeaderControlsCluster.astro";

interface Props {
  localizedUrls: LocalizedUrls;
}

const { localizedUrls } = Astro.props;
---

<header>
  <HomeLink />
  <HeaderControlsCluster>
    <AccentColorPicker />
    <ThemeToggle />
    <LanguagePicker localizedUrls={localizedUrls} />
  </HeaderControlsCluster>
</header>

<style>
  header {
    display: flex;
    min-height: 2rem;
    border-bottom: 1px solid var(--text-color);
  }

  header :global(.home-link) {
    margin-right: auto;
  }

  :global(.header-button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 2px solid transparent;
    border-radius: 0.5rem;
    background: none;
    color: var(--text-color);
    cursor: pointer;
    font-size: inherit;
    padding: 0.5rem 0.75rem;
    height: 100%;
    width: 100%;
  }

  :global(.header-button:hover) {
    background-color: var(--hover-background-color);
  }

  :global(.header-button[aria-expanded="true"]) {
    border: 2px solid var(--accent-color);
    background-color: var(--hover-background-color);
  }

  :global(.header-control) {
    position: relative;
  }

  :global(.header-menu) {
    display: none;
    position: absolute;
    list-style: none;
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    background-color: var(--background-color);
    box-shadow: 0 0.75rem 1.5rem var(--header-menu-shadow-color);
    overflow: hidden;
    width: max-content;
    padding: 0;
    margin: 0;
    top: calc(100% + 0.35rem);
    left: 50%;
    transform: translateX(-50%);
  }

  :global(.header-button[aria-expanded="true"] ~ .header-menu) {
    display: block;
  }
</style>

<script>
  import { initHeaderMenus, initHeaderDismiss } from "./headerMenu";

  initHeaderMenus();
  initHeaderDismiss();
</script>
