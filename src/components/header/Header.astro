---
import LanguagePicker from "./LanguagePicker.astro";
import ThemeToggle from "./ThemeToggle.astro";
import AccentColorPicker from "./accent-color-picker/AccentColorPicker.astro";
---

<header>
  <AccentColorPicker />
  <ThemeToggle />
  <LanguagePicker />
</header>

<style>
  header {
    display: flex;
    justify-content: flex-end;
    min-height: 2rem;
  }

  :global(.header-button) {
    border: 2px solid transparent;
    border-radius: 0.5rem;
    background: none;
    color: var(--text-color);
    cursor: pointer;
    font-size: inherit;
    padding: 0.5rem 0.75rem;
    height: 100%;
  }

  :global(.header-button:hover) {
    border: 2px solid var(--accent-color);
  }

  :global(.header-button[aria-expanded="true"]) {
    border: 2px solid var(--accent-color);
  }

  :global(.header-control) {
    position: relative;
  }

  :global(.header-menu) {
    position: absolute;
    list-style: none;
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    background-color: var(--background-color);
    min-width: 9rem;
    width: max-content;
    padding: 0;
    margin: 0;
    top: calc(100% + 0.35rem);
    left: 50%;
    transform: translateX(-50%);
  }
</style>

<script>
  import { initHeaderMenus } from "./headerMenu";

  initHeaderMenus();
</script>
