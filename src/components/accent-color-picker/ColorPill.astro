---
const { color } = Astro.props;
---

<span class="color-pill"></span>

<style define:vars={{ color }}>
  .color-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    background-color: var(--color);
    border-radius: 50%;
  }
</style>
