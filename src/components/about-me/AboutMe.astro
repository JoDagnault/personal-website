---
import { resolveLocale, type Locale } from "../../i18n/locales";
import AboutMeContentEn from "./AboutMeContent.en.astro";
import AboutMeContentFr from "./AboutMeContent.fr.astro";

const aboutContentByLang = {
  en: AboutMeContentEn,
  fr: AboutMeContentFr,
} satisfies Record<Locale, typeof AboutMeContentEn>;

const locale = resolveLocale(Astro.currentLocale);
const AboutMeContent = aboutContentByLang[locale];
---

<section class="about-me-section">
  <div class="about-me-description">
    <AboutMeContent />
  </div>
</section>

<style>
  .about-me-description {
    font-size: clamp(1rem, 3vw, 1.5rem);
    line-height: 1.5;
    text-align: center;
  }

  .about-me-description :global(p) {
    margin: 0;
  }

  .about-me-description :global(strong) {
    font-weight: 700;
    color: var(--accent-color);
  }
</style>
