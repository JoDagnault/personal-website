---
import type { Locale } from "../../i18n/config";
import AboutMeContentEn from "./AboutMeContent.en.astro";
import AboutMeContentFr from "./AboutMeContent.fr.astro";

interface Props {
  locale: Locale;
}

const aboutContentByLang = {
  en: AboutMeContentEn,
  fr: AboutMeContentFr,
} satisfies Record<Locale, typeof AboutMeContentEn>;

const { locale } = Astro.props;
const AboutMeContent = aboutContentByLang[locale];
---

<section class="about-me-section">
  <p class="about-me-description">
    <AboutMeContent />
  </p>
</section>

<style>
  .about-me-section {
    background-color: var(--color-background);
  }

  .about-me-description {
    font-size: clamp(1rem, 3vw, 1.5rem);
    text-align: center;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .about-me-description :global(strong) {
    font-weight: 700;
    color: var(--color-accent);
  }
</style>
