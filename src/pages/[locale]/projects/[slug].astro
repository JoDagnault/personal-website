---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import ProjectLayout from "../../../layouts/ProjectLayout.astro";
import { localizedUrlsForProject } from "../../../i18n/urls.ts";

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");

  return projects.map((project) => {
    const [locale, slug] = project.id.split("/");
    const localizedUrls = localizedUrlsForProject(project.data.key, projects);

    return {
      params: { locale, slug },
      props: { project, localizedUrls },
    };
  });
}) satisfies GetStaticPaths;

const { project, localizedUrls } = Astro.props;
const { Content } = await render(project);
---

<ProjectLayout
  title={project.data.title}
  description={project.data.description}
  tags={project.data.tags}
  repoUrl={project.data.repoUrl}
  localizedUrls={localizedUrls}
>
  <Content />
</ProjectLayout>
